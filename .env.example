# Spotify app credentials — https://developer.spotify.com/dashboard
# Register BOTH redirect URIs on the app:
#   https://sy.siv19.dev/api/auth/callback     (production)
#   http://127.0.0.1:3000/api/auth/callback    (local dev — Spotify rejects `localhost`,
#                                               so develop at http://127.0.0.1:3000)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Public origin of the deployed app. Leave unset for local dev (derived from the request).
# Set in production so the OAuth redirect URI is stable behind the proxy.
# APP_URL=https://sy.siv19.dev
APP_URL=
